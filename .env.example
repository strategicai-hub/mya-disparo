# === RabbitMQ ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# === Redis (mesmo servidor do projeto principal, isolamento via prefixo por instância) ===
REDIS_URL=redis://:SENHA@HOST:6379/0

# === Provider por instância ===
# Cada instância pode ser "uazapi" (padrão) ou "meta" (Cloud API oficial).
# UAZAPI: webhook /mya-disparo-{id}. Meta: webhook /mya-disparo-meta-{id} (encaminhado pelo disparador).

UAZAPI_URL=https://strategicai.uazapi.com
META_GRAPH_VERSION=v22.0

# Instância 1 (UAZAPI)
PROVIDER_1=uazapi
UAZAPI_INSTANCE_1=NOME_DA_INSTANCIA_1
UAZAPI_TOKEN_1=TOKEN_DA_INSTANCIA_1

# Instância 2 (UAZAPI)
PROVIDER_2=uazapi
UAZAPI_INSTANCE_2=NOME_DA_INSTANCIA_2
UAZAPI_TOKEN_2=TOKEN_DA_INSTANCIA_2

# Instância 3 (UAZAPI)
PROVIDER_3=uazapi
UAZAPI_INSTANCE_3=NOME_DA_INSTANCIA_3
UAZAPI_TOKEN_3=TOKEN_DA_INSTANCIA_3

# Instância "gustavo" (Meta Cloud API oficial)
PROVIDER_GUSTAVO=meta
META_PHONE_NUMBER_ID_GUSTAVO=
META_ACCESS_TOKEN_GUSTAVO=

# Segredo compartilhado com o disparador-whatsapp para autenticar o forward Meta
CHATBOT_FORWARD_SECRET=

# === Alerta de reunião agendada (grupo WhatsApp) ===
# Token dedicado de uma instância que seja membro do grupo
UAZAPI_ALERT_GROUP_TOKEN=TOKEN_INSTANCIA_ALERTAS
UAZAPI_ALERT_GROUP_ID=120363402718927307@g.us

# === Owner (alertas de ATENDIMENTO_HUMANO e bypass de debounce) ===
OWNER_NUMBER=5511989887525

# === LLM (Gemini) ===
LLM_API_KEY=SUA_API_KEY_GEMINI

# === Google (Sheets/Calendar compartilhados entre instâncias) ===
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CALENDAR_ID=SEU_CALENDAR_ID
GOOGLE_IMPERSONATE_USER=usuario@dominio.com

# === CRM Básico (compartilhado) ===
CRM_API_URL=https://crm-basico.strategicai.com.br/api/integrations/lead
CRM_API_KEY=SUA_CRM_API_KEY
CRM_OWNER_ID=SEU_CRM_OWNER_ID
