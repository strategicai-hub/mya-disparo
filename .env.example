# === RabbitMQ ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# === Redis (mesmo servidor do projeto principal, isolamento via prefixo nas chaves) ===
REDIS_URL=redis://:SENHA@HOST:6379/0

# === UAZAPI (nova instância WhatsApp) ===
UAZAPI_URL=https://strategicai.uazapi.com
UAZAPI_INSTANCE=NOME_DA_INSTANCIA
UAZAPI_TOKEN=TOKEN_DA_INSTANCIA

# === LLM (Gemini) ===
LLM_API_KEY=SUA_API_KEY_GEMINI

# === Google Sheets (mesmo service account, nova planilha) ===
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
