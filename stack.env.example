# Envs de RUNTIME do stack mya-disparo no Portainer.
# Copie para stack.env (gitignored) e preencha com os valores reais.
# scripts/update_stack.py lê este arquivo e publica no Portainer via API.

# --- RabbitMQ (infra compartilhada) ---
RABBITMQ_HOST=91.98.64.92
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_VHOST=default

# --- Redis (infra compartilhada) ---
REDIS_URL=

# --- UAZAPI multi-instância ---
UAZAPI_URL=https://strategicai.uazapi.com

# Instância 1 (atual)
UAZAPI_INSTANCE_1=mya-sdr-redrive-1
UAZAPI_TOKEN_1=

# Instância 2 (nova)
UAZAPI_INSTANCE_2=
UAZAPI_TOKEN_2=

# Instância 3 (nova)
UAZAPI_INSTANCE_3=
UAZAPI_TOKEN_3=

# Alerta "lead_agendou" → grupo WhatsApp
UAZAPI_ALERT_GROUP_TOKEN=
UAZAPI_ALERT_GROUP_ID=120363402718927307@g.us

# Número que recebe alertas de ATENDIMENTO_HUMANO e faz bypass de debounce
OWNER_NUMBER=5511989887525

# --- LLM ---
LLM_API_KEY=

# --- Google (Sheets/Calendar) ---
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=
GOOGLE_IMPERSONATE_USER=

# --- CRM Básico ---
CRM_API_URL=https://crm-basico.strategicai.com.br/api/integrations/lead
CRM_API_KEY=
CRM_OWNER_ID=

# --- Integração disparador-whatsapp (API Oficial Meta) ---
# Instância "disparo": recebe inbound do disparador-whatsapp e responde via Meta Cloud API.
# Webhook: POST /mya-disparo-meta-disparo
PROVIDER_DISPARO=meta
META_PHONE_NUMBER_ID_DISPARO=
META_ACCESS_TOKEN_DISPARO=

# Segredo compartilhado entre mya-disparo e disparador-whatsapp.
# Deve ser idêntico à var CHATBOT_FORWARD_SECRET do disparador-whatsapp.
CHATBOT_FORWARD_SECRET=

# URL do endpoint outbound do disparador para refletir respostas da Mya no inbox.
DISPARADOR_AUDIT_URL=https://disparador.strategicai.com.br/api/chatbot/outbound
